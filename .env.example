# ORIN Netlify/Vite environment variables

# Public client-side Google Maps key.
# Enable Maps JavaScript API.
# For 3D Maps, also make sure the Maps JavaScript 3D/maps3d capability is available for the key/project.
# This variable is intentionally public because browser Google Maps APIs need a client-side key.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Server-side Google API key for Air Quality (and other server-proxied Google calls).
# Enable "Air Quality API" on the project. Falls back to VITE_GOOGLE_MAPS_API_KEY if unset.
GOOGLE_API_KEY=your_google_api_key_here

# Optional app config
VITE_APP_NAME=ORIN
VITE_DEMO_MODE=true

# Crustdata — company / people enrichment (server-side only, never expose to client).
# Docs: fulldocs.crustdata.com
CRUSTDATA_TOKEN=your_crustdata_token_here
CRUSTDATA_EMAIL=your_crustdata_email_here
CRUSTDATA_PASSWORD=your_crustdata_password_here

# Upstash Redis (REST). Server-only — used for shared listings + API caches.
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here
