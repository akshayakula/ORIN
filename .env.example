# ORIN Netlify/Vite environment variables

# Public client-side Google Maps key.
# Enable Maps JavaScript API.
# For 3D Maps, also make sure the Maps JavaScript 3D/maps3d capability is available for the key/project.
# This variable is intentionally public because browser Google Maps APIs need a client-side key.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Server-only NASA FIRMS key.
# Get a free MAP_KEY from NASA FIRMS.
# Do NOT prefix with VITE_ because this must stay inside the Netlify Function.
NASA_FIRMS_MAP_KEY=your_nasa_firms_map_key_here

# Optional app config
VITE_APP_NAME=ORIN
VITE_DEMO_MODE=true
